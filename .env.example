# Adzuna API — free registration at https://developer.adzuna.com/
# Adds broad job coverage beyond remote-only listings.
ADZUNA_APP_ID=APP_ID_HERE
ADZUNA_APP_KEY=APP_KEY_HERE

# The Muse API — optional, increases rate limits (default is 500 req/hr without key)
# Free registration at https://www.themuse.com/developers/api/v2
THEMUSE_API_KEY=API_KEY_HERE
